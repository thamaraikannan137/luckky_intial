generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  staff
}

enum CustomerType {
  B2B
  B2C
}

enum ProductUnit {
  per_sqft
  per_letter
  per_piece
  per_design
}

enum OrderStatus {
  active
  cancelled
}

enum PaymentType {
  advance
  partial
  final_balance
  refund
}

enum PaymentMode {
  cash
  upi
  bank_transfer
  cheque
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(staff)
  displayName  String   @map("display_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ordersCreated Order[]   @relation("OrderCreatedBy")
  payments      Payment[] @relation("PaymentRecordedBy")

  @@map("users")
}

model Customer {
  id            String       @id @default(uuid())
  customerCode  String       @unique @map("customer_code")
  type          CustomerType
  name          String
  contactPerson String?      @map("contact_person")
  phone         String
  address       String?
  area          String?
  gstin         String?
  notes         String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  orders Order[]

  @@index([phone])
  @@index([name])
  @@index([type])
  @@map("customers")
}

model Product {
  id          String      @id @default(uuid())
  productCode String      @unique @map("product_code")
  name        String      @unique
  unit        ProductUnit
  cost        Decimal     @default(0) @db.Decimal(12, 2)
  rate        Decimal     @db.Decimal(12, 2)
  stockQty    Decimal     @default(0) @map("stock_qty") @db.Decimal(12, 2)
  lowStockAt  Decimal     @default(10) @map("low_stock_at") @db.Decimal(12, 2)
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id             String      @id @default(uuid())
  orderCode      String      @unique @map("order_code")
  customerId     String      @map("customer_id")
  orderDate      DateTime    @map("order_date") @db.Date
  deliveryDate   DateTime    @map("delivery_date") @db.Date
  stage          Int         @default(0)
  discountAmount Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 2)
  internalNotes  String?     @map("internal_notes")
  status         OrderStatus @default(active)
  createdById    String?     @map("created_by")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  customer  Customer    @relation(fields: [customerId], references: [id])
  createdBy User?       @relation("OrderCreatedBy", fields: [createdById], references: [id])
  items     OrderItem[]
  payments  Payment[]

  @@index([customerId])
  @@index([deliveryDate])
  @@index([stage])
  @@index([orderDate])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String  @map("order_id")
  productId    String? @map("product_id")
  categoryName String  @map("category_name")
  description  String?
  qty          Decimal @db.Decimal(12, 2)
  rate         Decimal @db.Decimal(12, 2)
  amount       Decimal @db.Decimal(12, 2)
  lineNo       Int     @map("line_no")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id          String      @id @default(uuid())
  paymentCode String      @unique @map("payment_code")
  orderId     String      @map("order_id")
  type        PaymentType
  amount      Decimal     @db.Decimal(12, 2)
  paymentDate DateTime    @map("payment_date") @db.Date
  mode        PaymentMode
  referenceNo String?     @map("reference_no")
  notes       String?
  recordedById String?    @map("recorded_by")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  order      Order @relation(fields: [orderId], references: [id])
  recordedBy User? @relation("PaymentRecordedBy", fields: [recordedById], references: [id])

  @@index([orderId])
  @@index([paymentDate])
  @@map("payments")
}

model CompanySettings {
  id                   String   @id @default(uuid())
  businessName         String   @map("business_name")
  address              String
  phone                String
  email                String?
  gstin                String?
  defaultGstRate       Decimal  @default(18) @map("default_gst_rate") @db.Decimal(5, 2)
  invoicePrefix        String   @default("INV") @map("invoice_prefix")
  advanceReceiptPrefix String   @default("AR") @map("advance_receipt_prefix")
  invoiceFooterNote    String?  @map("invoice_footer_note")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("company_settings")
}

model DocumentSequence {
  id         String @id @default(uuid())
  docType    String @unique @map("doc_type")
  prefix     String?
  lastNumber BigInt @default(0) @map("last_number")
  fiscalYear Int    @map("fiscal_year")

  @@map("document_sequences")
}
